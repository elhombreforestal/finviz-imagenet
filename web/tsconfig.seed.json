{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist-seed",
    "rootDir": ".",
    "noEmit": false,

    "target": "ES2020",
    "module": "CommonJS",

    // override Next.js setting
    "moduleResolution": "node",

    // recommended for Node scripts
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["scripts/seed-from-xml.ts"]
}